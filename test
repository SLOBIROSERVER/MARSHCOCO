                ctx.fillStyle='rgba(0,0,0,0.55)';roundRect(ctx,barX-4,barY-4,barWidth+8,barHeight+8,14);ctx.fill();ctx.strokeStyle='rgba(255,255,255,0.2)';ctx.lineWidth=2;roundRect(ctx,barX-4,barY-4,barWidth+8,barHeight+8,14);ctx.stroke();
                const bgGrad=ctx.createLinearGradient(barX,barY,barX+barWidth,barY);bgGrad.addColorStop(0,'#1a1a1a');bgGrad.addColorStop(0.5,'#2a2a2a');bgGrad.addColorStop(1,'#1a1a1a');ctx.fillStyle=bgGrad;roundRect(ctx,barX,barY,barWidth,barHeight,10);ctx.fill();
                let barColor;if(progress<0.33)barColor=lerpColor('#ff3333','#ff9933',progress/0.33);else if(progress<0.66)barColor=lerpColor('#ff9933','#ffdd33',(progress-0.33)/0.33);else barColor=lerpColor('#ffdd33','#33dd33',(progress-0.66)/0.34);
                const filledHeight=barHeight*progress;const filledY=barY+barHeight-filledHeight;const fillGrad=ctx.createLinearGradient(barX,filledY,barX,barY+barHeight);fillGrad.addColorStop(0,lightenColor(barColor,0.3));fillGrad.addColorStop(0.5,barColor);fillGrad.addColorStop(1,darkenColor(barColor,0.3));ctx.fillStyle=fillGrad;roundRect(ctx,barX+2,filledY+2,barWidth-4,filledHeight-4,7);ctx.fill();
                if(filledHeight>8){const shineGrad=ctx.createLinearGradient(barX,filledY,barX+barWidth/2,filledY);shineGrad.addColorStop(0,'rgba(255,255,255,0.3)');shineGrad.addColorStop(1,'rgba(255,255,255,0)');ctx.fillStyle=shineGrad;roundRect(ctx,barX+3,filledY+3,barWidth/2-2,Math.min(filledHeight-6,30),5);ctx.fill();}
                ctx.strokeStyle='rgba(255,255,255,0.4)';ctx.lineWidth=2;roundRect(ctx,barX,barY,barWidth,barHeight,10);ctx.stroke();ctx.fillStyle='#fff';ctx.font='bold 11px "Segoe UI"';ctx.textAlign='center';ctx.fillText(Math.floor(progress*100)+'%',barX+barWidth/2,barY+barHeight+20);
                const circleX=barX+barWidth/2,circleY=barY-24,circleRadius=18;ctx.fillStyle='rgba(0,0,0,0.5)';ctx.beginPath();ctx.arc(circleX,circleY+2,circleRadius,0,Math.PI*2);ctx.fill();
                const circleGrad=ctx.createRadialGradient(circleX-4,circleY-4,2,circleX,circleY,circleRadius);circleGrad.addColorStop(0,'#4a4a6a');circleGrad.addColorStop(1,'#1a1a2e');ctx.fillStyle=circleGrad;ctx.beginPath();ctx.arc(circleX,circleY,circleRadius,0,Math.PI*2);ctx.fill();ctx.strokeStyle='#FFD700';ctx.lineWidth=3;ctx.stroke();ctx.strokeStyle='rgba(255,215,0,0.4)';ctx.lineWidth=6;ctx.stroke();ctx.fillStyle='#FFD700';ctx.font='bold 15px "Segoe UI"';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(currentLevel,circleX,circleY);
                const maxTextY=circleY-30;ctx.fillStyle='rgba(0,0,0,0.7)';const maxText='Max: '+maxLevel;ctx.font='bold 13px "Segoe UI"';const textWidth=ctx.measureText(maxText).width+14;roundRect(ctx,circleX-textWidth/2,maxTextY-12,textWidth,22,8);ctx.fill();ctx.strokeStyle='rgba(255,215,0,0.5)';ctx.lineWidth=1.5;roundRect(ctx,circleX-textWidth/2,maxTextY-12,textWidth,22,8);ctx.stroke();ctx.fillStyle='#FFD700';ctx.fillText(maxText,circleX,maxTextY+2);
            }

            function drawTrashCan(ctx,x,y,imgScaled,imgOriginal,label,wobble){
                ctx.save();const wx=wobble?(Math.random()-0.5)*wobble:0;ctx.translate(x+wx,y);
                let img=null;
                if(imagesReady&&imgScaled&&imgScaled.complete)img=imgScaled;
                else if(imgOriginal&&imgOriginal.complete&&imgOriginal.naturalWidth>0)img=imgOriginal;
                if(img){ctx.drawImage(img, -80, -100, 160, 200);}
                else{ctx.fillStyle='rgba(0,0,0,0.4)';ctx.beginPath();ctx.ellipse(0,10,32,12,0,0,Math.PI*2);ctx.fill();ctx.fillStyle='#888';roundRect(ctx,-24,-30,48,60,10);ctx.fill();}
                ctx.fillStyle='rgba(0,0,0,0.6)';roundRect(ctx,-18,38,36,18,6);ctx.fill();ctx.fillStyle='#fff';ctx.font='bold 10px "Segoe UI"';ctx.textAlign='center';ctx.fillText(label,0,51);
                ctx.restore();
            }

            function drawChimney(ctx){
                let img = null;
                if (imagesReady && chimneyScaled && chimneyScaled.complete) img = chimneyScaled;
                else if (chimneyImage.complete && chimneyImage.naturalWidth > 0) img = chimneyImage;
                if (img) {
                    const w = CHIMNEY_TARGET_WIDTH, h = CHIMNEY_TARGET_HEIGHT;
                    ctx.drawImage(img, CHIMNEY_X - w/2, 0, w, h);
                } else {
                    const cx=CHIMNEY_X,cy=10,chW=136,chH=164;
                    const brickGrad=ctx.createLinearGradient(cx-chW/2,0,cx+chW/2,0);brickGrad.addColorStop(0,'#6b3020');brickGrad.addColorStop(0.2,'#8b4535');brickGrad.addColorStop(0.5,'#9b5040');brickGrad.addColorStop(0.8,'#8b4535');brickGrad.addColorStop(1,'#6b3020');ctx.fillStyle=brickGrad;roundRect(ctx,cx-chW/2,cy,chW,chH,10);ctx.fill();ctx.strokeStyle='rgba(0,0,0,0.25)';ctx.lineWidth=1.5;
                    for(let row=0;row<6;row++){const by=cy+6+row*28;ctx.beginPath();ctx.moveTo(cx-chW/2+4,by);ctx.lineTo(cx+chW/2-4,by);ctx.stroke();const offset=row%2===0?0:chW/4;for(let col=-1;col<3;col++){const bx=cx-chW/2+6+col*(chW/2)+offset;if(bx<cx+chW/2-4&&bx>cx-chW/2+4){ctx.beginPath();ctx.moveTo(bx,by);ctx.lineTo(bx,Math.min(by+28,cy+chH-6));ctx.stroke();}}}
                    ctx.strokeStyle='rgba(0,0,0,0.5)';ctx.lineWidth=3;roundRect(ctx,cx-chW/2,cy,chW,chH,10);ctx.stroke();
                }
            }

            function drawCrocodile(ctx){
                const sway=Math.sin(frameCount*0.04)*4.5;const cx=crocX;const cy=CROC_Y+sway;let img=null;
                if(gameState===STATE.GAMEOVER){img=(imagesReady&&crocDeadScaled&&crocDeadScaled.complete)?crocDeadScaled:(crocImgDead.complete&&crocImgDead.naturalWidth>0)?crocImgDead:null;}
                else if(isLevelUp&&levelUpTimer>0){img=(imagesReady&&crocLevelUpScaled&&crocLevelUpScaled.complete)?crocLevelUpScaled:(crocImgLevelUp.complete&&crocImgLevelUp.naturalWidth>0)?crocImgLevelUp:null;}
                else if(isHurt&&hurtTimer>0){img=(imagesReady&&crocHurtScaled&&crocHurtScaled.complete)?crocHurtScaled:(crocImgHurt.complete&&crocImgHurt.naturalWidth>0)?crocImgHurt:null;}
                else{const isChewing=crocMouthOpen>1.5||crocMouthTarget>2;if(imagesReady){img=(isChewing&&crocOpenScaled&&crocOpenScaled.complete)?crocOpenScaled:(crocClosedScaled&&crocClosedScaled.complete)?crocClosedScaled:null;}if(!img){const original=isChewing?crocImgOpen:crocImgClosed;if(original&&original.complete&&original.naturalWidth>0)img=original;}}
                ctx.save();ctx.translate(cx,cy);
                if(img&&img.complete&&img.naturalWidth>0){if(img===crocClosedScaled||img===crocOpenScaled||img===crocHurtScaled||img===crocDeadScaled||img===crocLevelUpScaled){ctx.drawImage(img,-img.width/2,-img.height/2+20);}else{ctx.drawImage(img,-TARGET_CROC_WIDTH/2,-TARGET_CROC_HEIGHT/2+20,TARGET_CROC_WIDTH,TARGET_CROC_HEIGHT);}}
                else{ctx.fillStyle='#5aad48';roundRect(ctx,-90,-80,180,160,28);ctx.fill();ctx.fillStyle='#fff';ctx.beginPath();ctx.arc(-30,-40,16,0,Math.PI*2);ctx.fill();ctx.beginPath();ctx.arc(30,-40,16,0,Math.PI*2);ctx.fill();ctx.fillStyle='#1a1a1a';ctx.beginPath();ctx.arc(-26,-42,8,0,Math.PI*2);ctx.fill();ctx.beginPath();ctx.arc(34,-42,8,0,Math.PI*2);ctx.fill();}
                ctx.restore();
            }

            function drawBackground(ctx){
                let img = null;
                if (imagesReady && bgScaled && bgScaled.complete) img = bgScaled;
                else if (bgImage.complete && bgImage.naturalWidth > 0) img = bgImage;
                if (img) {
                    ctx.drawImage(img, 0, 0, BASE_WIDTH, BASE_HEIGHT);
                } else {
                    const wallGrad=ctx.createLinearGradient(0,0,0,BASE_HEIGHT);wallGrad.addColorStop(0,'#f8efe0');wallGrad.addColorStop(0.3,'#f2e4d0');wallGrad.addColorStop(0.6,'#ecdcc4');wallGrad.addColorStop(1,'#e0d0b8');ctx.fillStyle=wallGrad;ctx.fillRect(0,0,BASE_WIDTH,BASE_HEIGHT);
                }
            }

            let gameLoopId = null;
            function gameLoop(timestamp){
                if(!lastFrameTime)lastFrameTime=timestamp;
                let dt=(timestamp-lastFrameTime)/1000;if(dt>0.15)dt=0.15;if(dt<=0)dt=0.016;
                lastFrameTime=timestamp;frameCount++;resizeCanvas();update(dt);render(ctx);
                gameLoopId = requestAnimationFrame(gameLoop);
            }
            function update(dt){
                for(let i=particles.length-1;i>=0;i--){particles[i].update(dt);if(particles[i].isDead())particles.splice(i,1);}for(let i=smokeParticles.length-1;i>=0;i--){smokeParticles[i].update(dt);if(smokeParticles[i].isDead())smokeParticles.splice(i,1);}
                if(gameState===STATE.GAMEOVER){if(shakeDuration>0){shakeDuration-=dt;if(shakeDuration<=0)shakeAmount=0;else shakeAmount*=0.88;}return;}if(smokeActive){smokeTimer-=dt;if(smokeTimer>0&&Math.random()<0.7)spawnSmoke(canWobbleGreen>canWobbleYellow?TRASH_GREEN_X:TRASH_YELLOW_X,TRASH_CAN_Y-25,3);if(smokeTimer<=0){smokeActive=false;endGame('humo');return;}}
                if(slowMotionTimer>0)slowMotionTimer-=dt;if(levelUpDisplayTimer>0)levelUpDisplayTimer-=dt;if(isHurt){hurtTimer-=dt;if(hurtTimer<=0){isHurt=false;hurtTimer=0;}}if(isLevelUp){levelUpTimer-=dt;if(levelUpTimer<=0){isLevelUp=false;levelUpTimer=0;}}
                canWobbleYellow*=Math.exp(-3*dt);canWobbleGreen*=Math.exp(-3*dt);difficultyLevel=1+Math.floor(score/120);spawnInterval=Math.max(22,60-difficultyLevel*3);spawnTimer+=dt*60;
                if(spawnTimer>=spawnInterval&&gameState===STATE.PLAYING&&!smokeActive){spawnTimer=0;spawnMarshmallow();if(difficultyLevel>=3&&Math.random()<0.2)setTimeout(()=>{if(gameState===STATE.PLAYING)spawnMarshmallow();},150+Math.random()*200);}
                for(let i=marshmallows.length-1;i>=0;i--){const m=marshmallows[i];m.update(dt);if(m.recycling&&m.recycleProgress>=1)continue;if(!m.recycling){const c=checkCrocCollision(m);if(c){eatMarshmallow(m,i);continue;}if(m.isOffScreen())marshmallows.splice(i,1);}}
                let moveDir=0;if(keysPressed['ArrowLeft']||keysPressed['KeyA']||keysPressed['a']||mobileLeftPressed)moveDir=-1;if(keysPressed['ArrowRight']||keysPressed['KeyD']||keysPressed['d']||mobileRightPressed)moveDir=1;if(moveDir!==0&&gameState===STATE.PLAYING)crocTargetX+=moveDir*CROC_SPEED*dt;crocTargetX=Math.max(CROC_MOUTH_WIDTH/2+5,Math.min(BASE_WIDTH-CROC_MOUTH_WIDTH/2-5,crocTargetX));crocX+=(crocTargetX-crocX)*Math.min(1,14*dt);crocMouthOpen+=(crocMouthTarget-crocMouthOpen)*Math.min(1,10*dt);if(Math.abs(crocMouthTarget-crocMouthOpen)<0.3)crocMouthTarget=0;if(comboTimer>0){comboTimer-=dt;if(comboTimer<=0)comboCount=0;}if(shakeDuration>0){shakeDuration-=dt;if(shakeDuration<=0)shakeAmount=0;else shakeAmount*=Math.exp(-6*dt);}
            }
            function render(ctx){
                ctx.clearRect(0,0,BASE_WIDTH,BASE_HEIGHT);let sx=0,sy=0;if(shakeAmount>0.3){sx=(Math.random()-0.5)*shakeAmount*2;sy=(Math.random()-0.5)*shakeAmount*2;}ctx.save();ctx.translate(sx,sy);
                drawBackground(ctx);drawLevelBar(ctx);drawChimney(ctx);
                drawTrashCan(ctx,TRASH_YELLOW_X,TRASH_CAN_Y,trashYellowScaled,trashYellowImg,'AMARILLO',canWobbleYellow);
                drawTrashCan(ctx,TRASH_GREEN_X,TRASH_CAN_Y,trashGreenScaled,trashGreenImg,'VERDE',canWobbleGreen);
                for(const m of marshmallows)m.draw(ctx);if(swipeActive&&swipedMarshmallow){const m=swipedMarshmallow,dx=swipeCurrentX-swipeStartX,a=Math.atan2(swipeCurrentY-swipeStartY,dx);ctx.strokeStyle=m.aura==='yellow'?'rgba(249,229,71,0.7)':'rgba(92,230,92,0.7)';ctx.lineWidth=3;ctx.setLineDash([6,5]);ctx.beginPath();ctx.moveTo(m.x,m.y);ctx.lineTo(m.x+Math.cos(a)*45,m.y+Math.sin(a)*45);ctx.stroke();ctx.setLineDash([]);}
                for(const p of particles)p.draw(ctx);for(const s of smokeParticles)s.draw(ctx);if(smokeActive&&smokeTimer<2.0){ctx.fillStyle=`rgba(25,25,25,${Math.min(0.65,(1-smokeTimer/2.8)*0.85)})`;ctx.fillRect(0,0,BASE_WIDTH,BASE_HEIGHT);}drawCrocodile(ctx);ctx.restore();if(slowMotionTimer>0){ctx.fillStyle='rgba(100,150,255,0.06)';ctx.fillRect(0,0,BASE_WIDTH,BASE_HEIGHT);}
            }

            let mobileLeftPressed=false,mobileRightPressed=false;
            window.addEventListener('keydown',e=>{keysPressed[e.code]=true;if(['ArrowLeft','ArrowRight','KeyA','KeyD'].includes(e.code))e.preventDefault();if((e.code==='Space'||e.code==='KeyR')&&gameState===STATE.GAMEOVER)restartGame();});window.addEventListener('keyup',e=>{keysPressed[e.code]=false;});
            canvas.addEventListener('mousedown',e=>{if(gameState!==STATE.PLAYING)return;const c=getCanvasCoords(e);const m=findSwipableMarshmallow(c.x,c.y);if(m){startSwipe(m,c.x,c.y);e.preventDefault();}else handleMarshmallowClick(c.x,c.y);});window.addEventListener('mousemove',e=>{if(swipeActive){const c=getCanvasCoords(e);updateSwipe(c.x,c.y);}});window.addEventListener('mouseup',()=>{if(swipeActive)endSwipe();});
            canvas.addEventListener('touchstart',e=>{if(gameState!==STATE.PLAYING)return;const t=e.touches[0];if(!t)return;const c=getCanvasCoords(t);const m=findSwipableMarshmallow(c.x,c.y);if(m){startSwipe(m,c.x,c.y);e.preventDefault();}else if(handleMarshmallowClick(c.x,c.y))e.preventDefault();},{passive:false});canvas.addEventListener('touchmove',e=>{if(!swipeActive)return;e.preventDefault();const t=e.touches[0];if(!t)return;const c=getCanvasCoords(t);updateSwipe(c.x,c.y);},{passive:false});canvas.addEventListener('touchend',e=>{if(swipeActive){e.preventDefault();endSwipe();}});canvas.addEventListener('touchcancel',()=>{if(swipeActive)endSwipe();});
            btnLeft.addEventListener('pointerdown',e=>{e.preventDefault();mobileLeftPressed=true;});btnLeft.addEventListener('pointerup',e=>{e.preventDefault();mobileLeftPressed=false;});btnLeft.addEventListener('pointerleave',()=>{mobileLeftPressed=false;});btnRight.addEventListener('pointerdown',e=>{e.preventDefault();mobileRightPressed=true;});btnRight.addEventListener('pointerup',e=>{e.preventDefault();mobileRightPressed=false;});btnRight.addEventListener('pointerleave',()=>{mobileRightPressed=false;});[btnLeft,btnRight].forEach(b=>{b.addEventListener('touchstart',e=>{e.preventDefault();if(b===btnLeft)mobileLeftPressed=true;else mobileRightPressed=true;});b.addEventListener('touchend',e=>{e.preventDefault();mobileLeftPressed=false;mobileRightPressed=false;});b.addEventListener('touchcancel',()=>{mobileLeftPressed=false;mobileRightPressed=false;});});btnRestart.addEventListener('click',restartGame);
            function checkMobile(){mobileControls.style.display=(/Android|iPhone|iPad|iPod|webOS/i.test(navigator.userAgent)||('ontouchstart' in window&&window.innerWidth<769))?'flex':'none';}checkMobile();window.addEventListener('resize',checkMobile);

            function startGame() {
                startScreen.style.display = 'none';
                resizeCanvas();loadProgress();levelThreshold=getThresholdForLevel(currentLevel);
                updateScoreUI();updateLivesUI();scoreDisplay.textContent=score;
                crocX=BASE_WIDTH/2;crocTargetX=BASE_WIDTH/2;
                prepareScaledImages();
                for(let i=0;i<2;i++)setTimeout(()=>{if(gameState===STATE.PLAYING)spawnMarshmallow();},i*500);
                lastFrameTime=performance.now();
                gameLoopId = requestAnimationFrame(gameLoop);
            }

            btnPlay.addEventListener('click', startGame);
            btnPlay.addEventListener('touchend', (e) => { e.preventDefault(); startGame(); });
        })();
    </script>
