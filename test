<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>🐊 CrocoMalvaviscos - Edición Profesional</title>
    <style>
        :root {
            --bg: #1a1a2e;
            --gold: #f0c27a;
            --pink: #ff9a9e;
            --white: #fdfcfb;
            --blue: #a1c4fd;
            --brown: #8b5e3c;
            --yellow-aura: #f9e547;
            --green-aura: #5ce65c;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: #0a0a15;
            background-image:
                radial-gradient(ellipse at 50% 30%, #1a1a35 0%, #0a0a15 60%),
                repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(255,255,255,0.008) 3px, rgba(255,255,255,0.008) 4px),
                repeating-linear-gradient(90deg, transparent, transparent 3px, rgba(255,255,255,0.008) 3px, rgba(255,255,255,0.008) 4px);
            display: flex; justify-content: center; align-items: center; min-height: 100vh;
            font-family: 'Segoe UI', 'Poppins', 'Nunito', system-ui, sans-serif;
            overflow-x: hidden; user-select: none; -webkit-user-select: none;
            -webkit-tap-highlight-color: transparent; -webkit-touch-callout: none; padding: 10px;
        }
        .game-wrapper {
            position: relative;
            background: linear-gradient(180deg, #1a1a32 0%, #1e1e3a 30%, #1c1c35 100%);
            border-radius: 28px;
            box-shadow:
                0 25px 80px rgba(0,0,0,0.6),
                0 0 0 4px rgba(255,255,255,0.1),
                0 0 0 8px rgba(0,0,0,0.4),
                0 0 150px rgba(240,194,122,0.12),
                inset 0 0 80px rgba(0,0,0,0.2);
            overflow: hidden; max-width: 750px; width: 100%;
            aspect-ratio: 700/580; max-height: 90vh;
            transition: transform 0.3s ease;
        }
        .game-wrapper:hover { transform: translateY(-3px); box-shadow: 0 30px 90px rgba(0,0,0,0.65), 0 0 0 4px rgba(255,255,255,0.15), 0 0 0 8px rgba(0,0,0,0.4), 0 0 170px rgba(240,194,122,0.18); }
        canvas { display: block; width: 100%; height: 100%; border-radius: 26px; cursor: default; touch-action: none; }
        .ui-overlay { position: absolute; top: 14px; left: 18px; right: 18px; display: flex; justify-content: space-between; align-items: flex-start; pointer-events: none; z-index: 10; gap: 10px; }
        .score-pill {
            background: rgba(0,0,0,0.6); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
            border: 2px solid rgba(255,255,255,0.25); border-radius: 50px; padding: 10px 20px;
            color: #fff; font-weight: 700; font-size: 1.05rem; display: flex; align-items: center; gap: 10px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.1);
            text-shadow: 0 2px 4px rgba(0,0,0,0.5);
        }
        .score-pill .icon { font-size: 1.4rem; filter: drop-shadow(0 2px 2px rgba(0,0,0,0.4)); }
        .score-pill .value { font-size: 1.3rem; color: #ffd700; min-width: 45px; text-align: center; font-weight: 900; }
        .lives-pill {
            background: rgba(0,0,0,0.6); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
            border: 2px solid rgba(255,255,255,0.25); border-radius: 50px; padding: 10px 18px;
            color: #fff; font-weight: 700; font-size: 1.05rem; display: flex; align-items: center; gap: 6px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.1);
        }
        .lives-pill .heart { font-size: 1.3rem; transition: all 0.3s ease; filter: drop-shadow(0 2px 2px rgba(0,0,0,0.4)); }
        .lives-pill .heart.lost { opacity: 0.2; transform: scale(0.65); filter: grayscale(1) drop-shadow(0 0 0 transparent); }
        .combo-indicator { position: absolute; top: 45%; left: 50%; transform: translate(-50%, -50%) scale(0); font-size: 3rem; font-weight: 900; color: #ffd700; text-shadow: 0 0 40px rgba(255,215,0,0.9), 0 0 80px rgba(255,180,0,0.7), 0 6px 12px rgba(0,0,0,0.6); pointer-events: none; z-index: 20; transition: transform 0.15s cubic-bezier(0.175, 0.885, 0.32, 1.275); opacity: 0; letter-spacing: 2px; }
        .combo-indicator.show { transform: translate(-50%, -50%) scale(1); opacity: 1; }
        .combo-indicator.hide { transform: translate(-50%, -50%) scale(1.6); opacity: 0; transition: transform 0.5s ease-out, opacity 0.5s ease-out; }
        .hint-text { display: none; } /* Oculto definitivamente */
        .level-up-popup { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) scale(0); font-size: 4rem; font-weight: 900; color: #FFD700; text-shadow: 0 0 50px rgba(255,215,0,1), 0 0 100px rgba(255,180,0,0.8), 0 8px 16px rgba(0,0,0,0.7); pointer-events: none; z-index: 25; transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275); opacity: 0; letter-spacing: 3px; }
        .level-up-popup.show { transform: translate(-50%, -50%) scale(1); opacity: 1; }
        .level-up-popup.hide { transform: translate(-50%, -50%) scale(2); opacity: 0; transition: transform 0.6s ease-out, opacity 0.6s ease-out; }
        .game-over-overlay {
            position: absolute; inset: 0;
            background: rgba(0,0,0,0.3); /* 70% transparencia -> 30% opacidad */
            backdrop-filter: blur(8px);
            display: flex; justify-content: center; align-items: center;
            z-index: 30; border-radius: 26px;
            opacity: 0; pointer-events: none;
            transition: opacity 0.5s ease;
        }
        .game-over-overlay.active { opacity: 1; pointer-events: all; }
        .game-over-card { background: linear-gradient(160deg, #1e1e42 0%, #28285a 50%, #1e1e42 100%); border: 3px solid rgba(255,255,255,0.2); border-radius: 24px; padding: 35px 40px; text-align: center; color: #fff; box-shadow: 0 25px 60px rgba(0,0,0,0.7), inset 0 2px 0 rgba(255,255,255,0.08); max-width: 400px; width: 90%; }
        .game-over-card h2 { font-size: 2.2rem; margin-bottom: 8px; text-shadow: 0 0 30px rgba(255,215,0,0.5); }
        .game-over-card .final-score { font-size: 4rem; font-weight: 900; color: #ffd700; margin: 12px 0; text-shadow: 0 0 40px rgba(255,215,0,0.7), 0 4px 8px rgba(0,0,0,0.5); }
        .btn-restart { background: linear-gradient(135deg, #ffd700 0%, #ffaa00 100%); border: none; color: #1a1a2e; font-weight: 800; font-size: 1.15rem; padding: 16px 36px; border-radius: 50px; cursor: pointer; margin-top: 14px; transition: all 0.3s ease; box-shadow: 0 10px 30px rgba(255,170,0,0.4), 0 0 0 3px rgba(255,255,255,0.1); text-transform: uppercase; letter-spacing: 1px; }
        .btn-restart:hover { transform: translateY(-4px); box-shadow: 0 14px 40px rgba(255,170,0,0.55), 0 0 0 3px rgba(255,255,255,0.2); background: linear-gradient(135deg, #ffe44d 0%, #ffbb33 100%); }
        .mobile-controls { position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%); display: none; gap: 24px; z-index: 15; }
        .ctrl-btn { width: 64px; height: 64px; border-radius: 50%; background: rgba(255,255,255,0.12); backdrop-filter: blur(10px); border: 2px solid rgba(255,255,255,0.3); color: #fff; font-size: 2rem; display: flex; align-items: center; justify-content: center; transition: all 0.2s ease; -webkit-tap-highlight-color: transparent; box-shadow: 0 6px 20px rgba(0,0,0,0.3); }
        .ctrl-btn:active { background: rgba(255,255,255,0.3); transform: scale(0.85); border-color: rgba(255,255,255,0.6); box-shadow: 0 2px 8px rgba(0,0,0,0.3); }
        /* Pantalla de inicio */
        .start-screen {
            position: absolute; inset: 0; background: rgba(0,0,0,0.92); backdrop-filter: blur(10px);
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            z-index: 50; border-radius: 26px; color: #fff; text-align: center; gap: 20px;
        }
        .start-screen h1 { font-size: 2.2rem; font-weight: 900; letter-spacing: 2px; text-shadow: 0 0 30px rgba(255,215,0,0.8); }
        .start-screen h2 { font-size: 1.3rem; font-weight: 600; color: #ffd700; letter-spacing: 1px; }
        .start-screen .version-text { font-size: 1rem; color: #ccc; letter-spacing: 1px; margin-top: -10px; }
        .start-screen .btn-play {
            background: linear-gradient(135deg, #ffd700 0%, #ffaa00 100%); border: none; color: #1a1a2e;
            font-weight: 800; font-size: 1.3rem; padding: 16px 40px; border-radius: 50px; cursor: pointer;
            transition: all 0.3s ease; box-shadow: 0 10px 30px rgba(255,170,0,0.4);
            text-transform: uppercase; letter-spacing: 2px;
        }
        .start-screen .btn-play:hover { transform: scale(1.05); box-shadow: 0 14px 40px rgba(255,170,0,0.6); }
        @media (max-width: 768px) { .mobile-controls { display: flex; } .game-wrapper { border-radius: 18px; } canvas { border-radius: 16px; } }
    </style>
</head>
<body>
    <!-- Precarga de todas las imágenes -->
    <img src="https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260618_211942.png" style="display:none;" alt="">
    <img src="https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260618_212002.png" style="display:none;" alt="">
    <img src="https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260618_213137.png" style="display:none;" alt="">
    <img src="https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260618_213541.png" style="display:none;" alt="">
    <img src="https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260618_212950.png" style="display:none;" alt="">
    <img src="https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260619_220331.png" style="display:none;" alt="">
    <img src="https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260619_210824.png" style="display:none;" alt="">
    <img src="https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260619_220721.png" style="display:none;" alt="">
    <img src="https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260619_221538.png" style="display:none;" alt="">
    <img src="https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260619_221707.png" style="display:none;" alt="">
    <img src="https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260619_221829.png" style="display:none;" alt="">
    <img src="https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260619_222038.png" style="display:none;" alt="">
    <img src="https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260619_222428.png" style="display:none;" alt="">

    <div class="game-wrapper" id="gameWrapper">
        <canvas id="gameCanvas"></canvas>
        <div class="ui-overlay">
            <div class="score-pill"><span class="icon">🍬</span><span class="value" id="scoreDisplay">0</span></div>
            <div class="lives-pill" id="livesDisplay"><span class="heart">❤️</span><span class="heart">❤️</span><span class="heart">❤️</span></div>
        </div>
        <div class="combo-indicator" id="comboIndicator"></div>
        <div class="level-up-popup" id="levelUpPopup"></div>
        <div class="hint-text" id="hintText"></div> <!-- Oculto por CSS -->
        <div class="game-over-overlay" id="gameOverOverlay">
            <div class="game-over-card">
                <h2 id="gameOverTitle">🐊 ¡Fin del Juego!</h2>
                <div class="final-score" id="finalScore">0</div>
                <p style="color:#ccc;">puntos totales</p>
                <div class="stats" style="display:flex;gap:24px;justify-content:center;margin:18px 0;flex-wrap:wrap;">
                    <span style="color:#ccc;">🍬 Atrapados <span class="stat-val" id="statCaught" style="color:#fff;font-size:1.5rem;">0</span></span>
                    <span style="color:#ccc;">🔄 Transformados <span class="stat-val" id="statTransformed" style="color:#fff;font-size:1.5rem;">0</span></span>
                    <span style="color:#ccc;">♻️ Reciclados <span class="stat-val" id="statRecycled" style="color:#fff;font-size:1.5rem;">0</span></span>
                    <span style="color:#ccc;">💀 Perdidos <span class="stat-val" id="statLost" style="color:#fff;font-size:1.5rem;">0</span></span>
                </div>
                <button class="btn-restart" id="btnRestart">🔄 Jugar de nuevo</button>
            </div>
        </div>
        <div class="mobile-controls" id="mobileControls">
            <button class="ctrl-btn" id="btnLeft">◀</button>
            <button class="ctrl-btn" id="btnRight">▶</button>
        </div>
        <!-- Pantalla de inicio -->
        <div class="start-screen" id="startScreen">
            <h1>🐊 SLOBIRO GAMES</h1>
            <h2>TEST MARSHCOCO</h2>
            <p class="version-text">in-dev 1.0.0</p>
            <button class="btn-play" id="btnPlay">▶ JUGAR</button>
        </div>
    </div>

    <script>
        (function() {
            const canvas = document.getElementById('gameCanvas');
            const ctx = canvas.getContext('2d');
            const gameWrapper = document.getElementById('gameWrapper');
            const startScreen = document.getElementById('startScreen');
            const btnPlay = document.getElementById('btnPlay');
            const scoreDisplay = document.getElementById('scoreDisplay');
            const livesDisplay = document.getElementById('livesDisplay');
            const comboIndicator = document.getElementById('comboIndicator');
            const levelUpPopup = document.getElementById('levelUpPopup');
            const hintText = document.getElementById('hintText');
            const gameOverOverlay = document.getElementById('gameOverOverlay');
            const gameOverTitle = document.getElementById('gameOverTitle');
            const finalScoreEl = document.getElementById('finalScore');
            const statCaughtEl = document.getElementById('statCaught');
            const statTransformedEl = document.getElementById('statTransformed');
            const statRecycledEl = document.getElementById('statRecycled');
            const statLostEl = document.getElementById('statLost');
            const btnRestart = document.getElementById('btnRestart');
            const btnLeft = document.getElementById('btnLeft');
            const btnRight = document.getElementById('btnRight');
            const mobileControls = document.getElementById('mobileControls');

            // Imágenes del cocodrilo
            const crocImgClosed = new Image(); const crocImgOpen = new Image(); const crocImgHurt = new Image(); const crocImgDead = new Image(); const crocImgLevelUp = new Image();
            crocImgClosed.crossOrigin = "anonymous"; crocImgOpen.crossOrigin = "anonymous"; crocImgHurt.crossOrigin = "anonymous"; crocImgDead.crossOrigin = "anonymous"; crocImgLevelUp.crossOrigin = "anonymous";
            crocImgClosed.src = "https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260618_211942.png";
            crocImgOpen.src = "https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260618_212002.png";
            crocImgHurt.src = "https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260618_213137.png";
            crocImgDead.src = "https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260618_213541.png";
            crocImgLevelUp.src = "https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260618_212950.png";

            // Imágenes de los botes
            const trashGreenImg = new Image(); const trashYellowImg = new Image();
            trashGreenImg.crossOrigin = "anonymous"; trashYellowImg.crossOrigin = "anonymous";
            trashGreenImg.src = "https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260619_220331.png";
            trashYellowImg.src = "https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260619_210824.png";

            // Imágenes de los bombones
            const marshPinkImg = new Image(); const marshBlueImg = new Image(); const marshWhiteImg = new Image(); const marshBrownImg = new Image();
            marshPinkImg.crossOrigin = "anonymous"; marshBlueImg.crossOrigin = "anonymous"; marshWhiteImg.crossOrigin = "anonymous"; marshBrownImg.crossOrigin = "anonymous";
            marshPinkImg.src = "https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260619_220721.png";
            marshBlueImg.src = "https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260619_221538.png";
            marshWhiteImg.src = "https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260619_221707.png";
            marshBrownImg.src = "https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260619_221829.png";

            // Nuevas imágenes: fondo y chimenea
            const bgImage = new Image(); const chimneyImage = new Image();
            bgImage.crossOrigin = "anonymous"; chimneyImage.crossOrigin = "anonymous";
            bgImage.src = "https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260619_222038.png";
            chimneyImage.src = "https://raw.githubusercontent.com/SLOBIROSERVER/MARSHCOCO/main/Copilot_20260619_222428.png";

            // Imágenes pre‑escaladas
            let crocClosedScaled = null, crocOpenScaled = null, crocHurtScaled = null, crocDeadScaled = null, crocLevelUpScaled = null;
            let trashGreenScaled = null, trashYellowScaled = null;
            let marshPinkScaled = null, marshBlueScaled = null, marshWhiteScaled = null, marshBrownScaled = null;
            let bgScaled = null, chimneyScaled = null;
            let imagesReady = false;

            const TARGET_CROC_WIDTH = 520;
            const TARGET_CROC_HEIGHT = 480;
            const TRASH_TARGET_WIDTH = 160;
            const TRASH_TARGET_HEIGHT = 200;
            const MARSH_TARGET_WIDTH = 64;
            const MARSH_TARGET_HEIGHT = 72;
            const BG_TARGET_WIDTH = 700;
            const BG_TARGET_HEIGHT = 580;
            const CHIMNEY_TARGET_WIDTH = 180;
            const CHIMNEY_TARGET_HEIGHT = 200;

            function preScaleImage(img, w, h) {
                const offCanvas = document.createElement('canvas');
                offCanvas.width = w; offCanvas.height = h;
                const offCtx = offCanvas.getContext('2d');
                offCtx.drawImage(img, 0, 0, w, h);
                const scaledImg = new Image();
                scaledImg.src = offCanvas.toDataURL();
                return scaledImg;
            }

            function prepareScaledImages() {
                let loaded = 0; const total = 13;
                function check() { loaded++; if (loaded >= total) imagesReady = true; }
                function scaleCroc(original, prop) {
                    if (original.complete && original.naturalWidth > 0) { const s = preScaleImage(original, TARGET_CROC_WIDTH, TARGET_CROC_HEIGHT); if (prop === 'closed') crocClosedScaled = s; else if (prop === 'open') crocOpenScaled = s; else if (prop === 'hurt') crocHurtScaled = s; else if (prop === 'dead') crocDeadScaled = s; else if (prop === 'levelup') crocLevelUpScaled = s; check(); }
                    else { original.onload = () => { const s = preScaleImage(original, TARGET_CROC_WIDTH, TARGET_CROC_HEIGHT); if (prop === 'closed') crocClosedScaled = s; else if (prop === 'open') crocOpenScaled = s; else if (prop === 'hurt') crocHurtScaled = s; else if (prop === 'dead') crocDeadScaled = s; else if (prop === 'levelup') crocLevelUpScaled = s; check(); }; }
                }
                function scaleTrash(original, prop) {
                    if (original.complete && original.naturalWidth > 0) { const s = preScaleImage(original, TRASH_TARGET_WIDTH, TRASH_TARGET_HEIGHT); if (prop === 'green') trashGreenScaled = s; else trashYellowScaled = s; check(); }
                    else { original.onload = () => { const s = preScaleImage(original, TRASH_TARGET_WIDTH, TRASH_TARGET_HEIGHT); if (prop === 'green') trashGreenScaled = s; else trashYellowScaled = s; check(); }; }
                }
                function scaleMarsh(original, prop) {
                    if (original.complete && original.naturalWidth > 0) { const s = preScaleImage(original, MARSH_TARGET_WIDTH, MARSH_TARGET_HEIGHT); if (prop === 'pink') marshPinkScaled = s; else if (prop === 'blue') marshBlueScaled = s; else if (prop === 'white') marshWhiteScaled = s; else if (prop === 'brown') marshBrownScaled = s; check(); }
                    else { original.onload = () => { const s = preScaleImage(original, MARSH_TARGET_WIDTH, MARSH_TARGET_HEIGHT); if (prop === 'pink') marshPinkScaled = s; else if (prop === 'blue') marshBlueScaled = s; else if (prop === 'white') marshWhiteScaled = s; else if (prop === 'brown') marshBrownScaled = s; check(); }; }
                }
                function scaleBg(original) {
                    if (original.complete && original.naturalWidth > 0) { bgScaled = preScaleImage(original, BG_TARGET_WIDTH, BG_TARGET_HEIGHT); check(); }
                    else { original.onload = () => { bgScaled = preScaleImage(original, BG_TARGET_WIDTH, BG_TARGET_HEIGHT); check(); }; }
                }
                function scaleChimney(original) {
                    if (original.complete && original.naturalWidth > 0) { chimneyScaled = preScaleImage(original, CHIMNEY_TARGET_WIDTH, CHIMNEY_TARGET_HEIGHT); check(); }
                    else { original.onload = () => { chimneyScaled = preScaleImage(original, CHIMNEY_TARGET_WIDTH, CHIMNEY_TARGET_HEIGHT); check(); }; }
                }
                scaleCroc(crocImgClosed, 'closed'); scaleCroc(crocImgOpen, 'open'); scaleCroc(crocImgHurt, 'hurt'); scaleCroc(crocImgDead, 'dead'); scaleCroc(crocImgLevelUp, 'levelup');
                scaleTrash(trashGreenImg, 'green'); scaleTrash(trashYellowImg, 'yellow');
                scaleMarsh(marshPinkImg, 'pink'); scaleMarsh(marshBlueImg, 'blue'); scaleMarsh(marshWhiteImg, 'white'); scaleMarsh(marshBrownImg, 'brown');
                scaleBg(bgImage);
                scaleChimney(chimneyImage);
            }

            const BASE_WIDTH = 700;
            const BASE_HEIGHT = 580;
            let scale = 1;
            function resizeCanvas() {
                const rect = gameWrapper.getBoundingClientRect();
                const maxW = rect.width, maxH = rect.height || (maxW / (BASE_WIDTH/BASE_HEIGHT));
                const dpr = Math.min(window.devicePixelRatio||1, 2);
                const targetW = Math.min(maxW, BASE_WIDTH), targetH = targetW / (BASE_WIDTH/BASE_HEIGHT);
                canvas.width = targetW * dpr; canvas.height = targetH * dpr;
                canvas.style.width = targetW + 'px'; canvas.style.height = targetH + 'px';
                scale = targetW / BASE_WIDTH;
                ctx.setTransform(1,0,0,1,0,0); ctx.scale(dpr*scale, dpr*scale);
            }
            window.addEventListener('resize', resizeCanvas); resizeCanvas();

            const STATE = { PLAYING: 'playing', GAMEOVER: 'gameover' };
            let gameState = STATE.PLAYING;
            let score = 0, lives = 3, comboCount = 0, comboTimer = 0;
            let totalCaught = 0, totalTransformed = 0, totalRecycled = 0, totalLost = 0;
            let marshmallows = [], particles = [], smokeParticles = [];
            let shakeAmount = 0, shakeDuration = 0;
            let spawnTimer = 0, spawnInterval = 60, difficultyLevel = 1;
            let crocX = BASE_WIDTH/2, crocTargetX = BASE_WIDTH/2, crocMouthOpen = 0, crocMouthTarget = 0;
            let keysPressed = {}, lastFrameTime = performance.now(), frameCount = 0;
            let swipedMarshmallow = null, swipeStartX = 0, swipeStartY = 0, swipeActive = false, swipeCurrentX = 0, swipeCurrentY = 0;
            let smokeActive = false, smokeTimer = 0, canWobbleYellow = 0, canWobbleGreen = 0;
            let slowMotionTimer = 0;
            let currentLevel = 1, maxLevel = 1, levelScore = 0, levelThreshold = 100, levelUpDisplayTimer = 0;
